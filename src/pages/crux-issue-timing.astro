---
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import CruxIssueTiming from "@components/crux/timing-report/index";
import { getValidCruxData } from "@components/cwv-data-utils/data-clean";
import cruxHistoryOtherSitesData from "@assets/sample-data/crux-history-othersites.json";
import cruxHistorySitesData from "@assets/data/crux-history-sites.json";
import Layout from "@layouts/Layout.astro";

const siteData = getValidCruxData({
  data: cruxHistorySitesData,
  cruxType: "origin",
  summaryOnly: false,
});
const otherSiteData = getValidCruxData({
  data: cruxHistoryOtherSitesData,
  cruxType: "origin",
  summaryOnly: false,
});
---

<Layout title="CrUX Issue Timing">
  <Container>
    <Sectionhead>
      <Fragment slot="title">CrUX Issue Timing</Fragment>
      <Fragment slot="desc">
        Core Web Vitals grouped by the collection period where each recent
        worsening or non-good run started.
      </Fragment>
    </Sectionhead>
    <div class="flex flex-col p-4">
      <CruxIssueTiming
        siteData={siteData}
        otherSiteData={otherSiteData}
        client:load
      />
    </div>
  </Container>
</Layout>
